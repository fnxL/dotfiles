!-- Xft settings -- !

Xft.antialias: 1

Xft.hinting: 1

Xft.autohint: 0

Xft.hintstyle: hintslight

Xft.rgba: rgb

Xft.lcdfilter: lcddefault

Xft.dpi: 96

! Base colors
*.foreground:       #63718B
*.background:       #20202A
*.cursorColor:      #2c2e3e

! Black
*.color0:           #3D4059
*.color8:           #1A1A24

! Red
*.color1:           #EBB9B9
*.color9:           #d95e59

! Green
*.color2:           #B1DBA4
*.color10:          #8fc587

! Yellow
*.color3:           #E6DFB8
*.color11:          #ffcf85

! Blue
*.color4:           #CDDBF9
*.color12:          #4a83c3

! magenta
*.color5:           #F6BBE7
*.color13:          #bf83b5

! Cyan
*.color6:           #B8DEEB
*.color14:          #4eb3cd

! white
*.color7:           #A7B7D6
*.color15:          #63718b

